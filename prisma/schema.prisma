generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Salary {
  id          Int      @id @default(autoincrement())

  company     String
  role        String
  level       String
  location    String

  baseSalary  Float
  stock       Float
  bonus       Float
  totalComp   Float

  createdAt   DateTime @default(now())

  @@index([company])
  @@index([role])
  @@index([location])
  @@index([totalComp])
}